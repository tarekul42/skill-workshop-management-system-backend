  "name": "skill-workshop-management-system-backend",
  "version": "1.0.0",
  "description": "A production-ready, highly secure, and scalable Node.js/TypeScript backend. Featuring RBAC, automated OTP verification via Redis, SSLCommerz integration, BullMQ background jobs, Pino structured logging, real-time audit trails, and Prometheus-based observability.",
  "main": "./dist/server.js",
  "scripts": {
    "test": "bun test tests/",
    "dev": "bun --watch ./src/server.ts",
    "lint": "bun x eslint ./src",
    "build": "tsc -p tsconfig.build.json && cp -r src/app/utils/templates dist/app/utils/",
    "start": "bun dist/server.js",
    "docker:up": "docker compose up --build"
  },
